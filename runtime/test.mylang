// test types in my language.
// right now, the language only has types, no actual logic.
// special "incompatible", "equal", "wider", and "narrower" assertions are
// supported for testing type comparisons.

type None;

// this creates a type alias
type MyAlias = string;

// this creates a named type
type MyNamedType string;

incompatible(MyAlias, MyNamedType);

equal({
  a: string,
  b: int,
}, {
  a: string,
  b: int,
});

type GenericAlias = <A, B> {
  a: A;
  b: B;
  ab: (A | B);
};

print(GenericAlias<B = string, A = int>);
print(GenericAlias<string, int>);