type and = <A, B> if (A) B else false;
type or = <A, B> if (A) true else B;
type not = <A> if (A) false else true;
type xor = <A, B> if (A) not<B> else B;

print(and<true, true>);
print(and<true, false>);
print(and<false, true>);
print(and<false, false>);
print(or<true, true>);
print(or<true, false>);
print(or<false, true>);
print(or<false, false>);
print(not<true>);
print(not<false>);
print(xor<true, true>);
print(xor<true, false>);
print(xor<false, true>);
print(xor<false, false>);
