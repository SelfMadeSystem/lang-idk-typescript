// type Name = ...; <-- this is a type alias
// type Name ...; <-- this is a type declaration (nominal type)
// generics are first-class citizens and can be used practically anywhere

type any = (<any>{a:any}).a;

type None;
type Some<T> T;
type Option = <T> (None | Some<T>);

type Ok<T> T;
type Err<E> E;
type Result = <T, E> (Ok<T> | Err<E>);

type LinkedList<T> {
  value: T;
  next: (LinkedList<T> | None);
};

type Box<T> {
  value: T;
};

type InferValue = <T: { value: any }> T.value;

print(InferValue<Box<{ hi: int }>>); // should print 'int'
