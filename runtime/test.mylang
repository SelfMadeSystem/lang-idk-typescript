// TODO: Make "test bench" mode

// named type
type User {
  name: string;
  age: int;
};

type Admin (User & {
  role: string;
});

// functions like "narrower", "wider", "equal" are just assertions for testing the type system
narrower(Admin, User);

type Some<T> T;
type None;
// Option is a type alias, not a named type (due to the `=`)
type Option = <T> (Some<T> | None);

wider(Option<int>, Some<int>);

type Ok<T> T;
type Err<E> E;
type Result = <T, E> (Ok<T> | Err<E>);

wider(Result<int, string>, Ok<int>);

type Box <T> {
  value: T;
};

type InferValue = <A> A.value;
equal(InferValue<Box<int>>, int);

type LinkedList<T> {
  value: T;
  next: (LinkedList<T> | None);
};

print(LinkedList<string>); // LinkedList{ value: string, next: (LinkedList<string> | None) }

type ApplyInt = <F> F<int>;
equal(ApplyInt<LinkedList>, LinkedList<int>);

type ThingA = <A> { a: A };
type ThingB = <B> { a: B, b: B };

equal((ThingA<number> & ThingB), <B: number>{ a: B, b: B });
equal((<A> { a: A }) & (<A> { b: A }), <A0, A1> { a: A0, b: A1 });

type and = <A: boolean, B: boolean> if (A) B else false;
type or = <A: boolean, B: boolean> if (A) true else B;

equal(and<true, true>, true);
equal(and<true, false>, false);
equal(or<true, false>, true);
equal(or<false, false>, false);

type Id int;
type UserId Id;

narrower(Id, int);
narrower(UserId, Id);

equal(int is int, true);
equal(Id extends int, true);
equal(UserId extends Id, true);

type Generic = <A, B> { a: A, b: B };
type GenInt = Generic<int>; // <B> { a: int, b: B }
type GenIntFloat = GenInt<float>; // { a: int, b: float }

equal(GenInt, <B> { a: int, b: B });
equal(GenIntFloat, { a: int, b: float });
